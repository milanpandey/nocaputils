<script>
    (function() {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-WLDY19X753');
        gtag('config', 'G-YN8J938QZE');

        var loaded = false;
        function loadGtag() {
            if (loaded) return;
            loaded = true;
            var s = document.createElement('script');
            s.src = 'https://www.googletagmanager.com/gtag/js?id=G-WLDY19X753';
            s.async = true;
            document.head.appendChild(s);
            cleanup();
        }

        var events = ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'];
        function cleanup() {
            events.forEach(function(e) {
                window.removeEventListener(e, loadGtag, { passive: true });
            });
        }
        events.forEach(function(e) {
            window.addEventListener(e, loadGtag, { passive: true, once: true });
        });

        // Fallback : charger après 4s même sans interaction
        setTimeout(loadGtag, 4000);

        // ═══════════════════════════════════════════════════════════════
        // GA4 : evenement « affiliate_click » (Thomann / Amazon)
        // Delegation globale : tout clic sur un lien sortant vers un affilie.
        // ═══════════════════════════════════════════════════════════════
        document.addEventListener('click', function(e){
            var a = e.target && e.target.closest ? e.target.closest('a') : null;
            if (!a || !a.href) return;
            var href = a.href;
            var network = '';
            if (/(^https?:\/\/)([^\/]*\.)?thomann\.de\//i.test(href) || /thmn\.to\//i.test(href) || /\/thomann\/?$/i.test(href)) {
                network = 'thomann';
            } else if (/amzn\.to\//i.test(href) || /(^https?:\/\/)([^\/]*\.)?amazon\./i.test(href) || /\/amazon\/?$/i.test(href)) {
                network = 'amazon';
            } else if (/(^https?:\/\/)([^\/]*\.)?aliexpress\.com\//i.test(href) || /s\.click\.aliexpress\.com\//i.test(href)) {
                network = 'aliexpress';
            }
            if (!network) return;
            gtag('event', 'affiliate_click', {
                affiliate_network: network,
                link_url: href,
                link_text: (a.textContent || '').trim().slice(0, 80),
                page_path: location.pathname
            });
        }, true);

        // ═══════════════════════════════════════════════════════════════
        // GA4 : evenement « sound_preview » global (tous les lecteurs du site)
        // Couvre detail.php, search.php, search_landing.php, widgets, etc.
        // Filtre sur les audios id='MyAudio<id>' ou 'MyAudio<id>_<lecteur>'.
        // 1 event par son par chargement de page (flag window.__ga4PreviewFired).
        // ═══════════════════════════════════════════════════════════════
        window.__ga4PreviewFired = window.__ga4PreviewFired || {};
        document.addEventListener('play', function(e){
            var audio = e.target;
            if (!audio || !audio.id) return;
            var m = /^MyAudio(\d+)(?:_[a-z])?$/.exec(audio.id);
            if (!m) return;
            var key = 's' + m[1];
            if (window.__ga4PreviewFired[key]) return;
            window.__ga4PreviewFired[key] = true;
            gtag('event', 'sound_preview', {
                sound_id: m[1],
                page_path: location.pathname
            });
        }, true);
    })();
    </script>



